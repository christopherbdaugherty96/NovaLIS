# ----------------------------
# Nova Runtime Exclusions
# ----------------------------

# Runtime ledgers
src/data/*.jsonl
memory/*.jsonl

# Models
models/
nova_backend/models/
vosk-model*

# Tools / binaries
tools/
nova_backend/tools/
*.exe
*.dll

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.env/

# IDE
.vscode/
.idea/
.obsidian/

# OS
.DS_Store
Thumbs.db

# Runtime audio / temp
nova_backend/input.m4a
nova_backend/test.wav

# Runtime state
nova_backend/memory/
nova_backend/src/data/

# Temporary audio
*.wav
*.m4a

# Local workspace artifacts
.claude/
New-Audit-and-Issues.md
Untitled.canvas
nova_backend/Untitled.base

# Environment secrets - NEVER commit this
nova_backend/.env
